# Frontend env (Vite). Copy to .env and adjust.
#
# Local dev (recommended): leave VITE_API_BASE_URL empty, run `npm run dev:all`
# (starts Laravel on :8001 + Vite; the dev server proxies /api/* to Laravel).
#
# XAMPP / custom API URL: set full base (no trailing slash), e.g.:
# VITE_API_BASE_URL=http://localhost/Beauty%20Clinic%20Management%20App%20(Final-2)/backend/public/api/v1
VITE_API_BASE_URL=
