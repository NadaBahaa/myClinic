APP_NAME="Beauty Clinic"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
FRONTEND_URL=https://your-domain.com

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Database (pick ONE setup below) ─────────────────────────────────────────

DB_CONNECTION=mysql
DB_PORT=3306

# Option A: MySQL on the same EC2 instance
# DB_HOST=127.0.0.1
# DB_DATABASE=beauty_clinic
# DB_USERNAME=clinic
# DB_PASSWORD=change-me

# Option B: Amazon RDS (recommended for production)
# DB_HOST=your-instance.xxxxxxx.us-east-1.rds.amazonaws.com
# DB_DATABASE=beauty_clinic
# DB_USERNAME=admin
# DB_PASSWORD=change-me

# Option C: Docker Sail (local/staging only)
# DB_HOST=mysql
# DB_DATABASE=beauty_clinic
# DB_USERNAME=sail
# DB_PASSWORD=password

DB_HOST=127.0.0.1
DB_DATABASE=beauty_clinic
DB_USERNAME=clinic
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@your-domain.com
MAIL_FROM_NAME="${APP_NAME}"

SMSMISR_ENVIRONMENT=1
SMSMISR_USERNAME=
SMSMISR_PASSWORD=
SMSMISR_TEST_SENDER=
SMSMISR_LIVE_SENDER=
